# Cloudflare credentials (only needed for CI/CD deployment)
# For local dev, wrangler uses browser-based auth (`wrangler login`).
CLOUDFLARE_API_TOKEN=your-api-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# --- Gateway secrets (set via `wrangler secret put <NAME>`) ---

# x402 recipient — Stacks address that receives payment (SP... mainnet / ST... testnet)
# wrangler secret put RECIPIENT_ADDRESS

# Upstream inference server (OpenAI-compatible): HF Inference Endpoint or vLLM.
# The gateway serves open-weight models from here — it does NOT resell a 3rd-party API.
# wrangler secret put UPSTREAM_BASE_URL   # e.g. https://xxxx.endpoints.huggingface.cloud/v1
# wrangler secret put UPSTREAM_API_KEY    # HF token / vLLM --api-key

# Optional (non-secret, can live in wrangler.jsonc vars):
#   PRICE_MARKUP  — multiple of serving cost charged to the agent (default 1.5)
